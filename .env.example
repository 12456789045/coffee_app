# Database Configuration for Streamlit Cloud
# Set to 'sqlite' for cloud deployment (default)
DB_TYPE=sqlite

# MySQL Configuration (only needed for local development)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=coffee_shop

# Application Settings
APP_NAME=Coffee Shop Management System
UPI_ID=merchant@upi
GST_RATE=0.05

# Security (Change these in production!)
SECRET_KEY=coffee-shop-secret-key-2024